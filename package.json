{
  "name": "tcode",
  "version": "0.4.0",
  "description": "A desktop code explorer with Claude integration — read-only file tree, syntax-highlighted viewer, fuzzy search and a git explorer, in an Electron window or a macOS app",
  "bin": {
    "tcode": "desktop/cli.js"
  },
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron desktop/main.js",
    "package:mac": "electron-builder --mac",
    "package:mac:dir": "electron-builder --mac --dir"
  },
  "files": [
    "desktop",
    "build",
    "install.sh",
    "run-desktop.sh"
  ],
  "license": "MIT",
  "author": "Adavance",
  "build": {
    "appId": "com.adavance.tcode",
    "productName": "tcode",
    "directories": {
      "buildResources": "build",
      "output": "dist-desktop"
    },
    "asarUnpack": [
      "**/node_modules/highlight.js/styles/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.10.0",
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^26.0.0"
  }
}
