{
  "name": "tcode",
  "version": "0.1.0",
  "description": "Read-only VS Code-like terminal explorer with Claude integration",
  "bin": {
    "tcode": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "[ ! -d src ] || npm run build"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "install.sh"
  ],
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "cli-highlight": "^2.1.11",
    "fuse.js": "^7.0.0",
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
